    "seg6": {
        "n1_h5n1", "n2_h6n2", "n2_h9n2", "n2_h5n2", "n3_h16n3", "n4_h8n4", "n5_h12n5", "n6_h4n6", "n6_h13n6", "n7_h10n7", "n8_h3n8", "n9_h7n9", "n9_h11n9", "n9_h15n9", "n10_h17n10", "n11_h18n11"
    }
}

SEGMENTS = ["seg4", "seg6"]
wildcard_constraints:
    segment = r"seg\d+"

def build_filter(segment):
    params = [
        ("dataUseTerms", "OPEN"),
        ("segments", ",".join(f"{segment}-{subtype}"for subtype in dataset_name_map[segment].keys())),
        ("versionStatus", "LATEST_VERSION"),
        ("isRevocation", "false"),
        (f"length_{segment}From", "100"),
        # ("hostNameScientific", "Homo sapiens"),
    ]

    return urlencode(params)


def fasta_url(wildcards):
    filter_string = build_filter(wildcards.segment)
    return (
        f"{LAPIS_URL}unalignedNucleotideSequences"
        f"?downloadAsFile=true"
        f"&downloadFileBasename=influenza-a_nuc-{wildcards.segment}_2026-03-16T1639"
        f"&fastaHeaderTemplate=%7BaccessionVersion%7D"
        f"&{filter_string}"
    )


rule all:
    input:
        expand("results/diamonddifferences_{segment}.tsv", segment=SEGMENTS),
        expand("results/sortdifferences_{segment}.tsv", segment=SEGMENTS)


rule download_sequences:
    output:
        fasta="results/segment_{segment}.fasta",
    params:
        url=fasta_url,
    shell:
        """
        curl -L "{params.url}" -o {output.fasta}
        """


rule align:
    input:
        sequences="results/segment_{segment}.fasta",
    output:
        results="results/aligned_{segment}_{subtype}.tsv",
    params:
        dataset_server=lambda w: GS_DATASET_SERVER if w.subtype in datasets_in_gs_server.get(w.segment, set()) else DATASET_SERVER,
        dataset_name=lambda w: dataset_name_map[w.segment][w.subtype],
    shell:
        """
        nextclade run \
            {input.sequences} \
            --output-tsv {output.results} \
            --server {params.dataset_server} \
            --dataset-name {params.dataset_name} \
        """


rule process_alignments:
    input:
        results=lambda w: expand(
            "results/aligned_{segment}_{subtype}.tsv",
            segment=w.segment,
            subtype=dataset_name_map[w.segment].keys(),
        ),
        script="parse_alignment_output.py",
    output:
        merged="results/nextclade_{segment}.tsv",
    params:
        segment_paths=lambda w: " ".join(
            f"--alignment-results results/aligned_{w.segment}_{subtype}.tsv"
            for subtype in dataset_name_map[w.segment].keys()
        ),
    shell:
        """
        python {input.script} \
            {params.segment_paths} \
            --output {output.merged}
        """

rule run_diamond:
    input:
        sequences="results/segment_{segment}.fasta",
        diamond_db="diamond.dmnd",
    output:
        diamond_output="results/diamond_{segment}.tsv",
    shell:
        """
        diamond blastx \
            --query {input.sequences} \
            --db {input.diamond_db} \
            --out {output.diamond_output} \
            --outfmt 6 qseqid sseqid pident length mismatch gapopen qstart qend sstart send evalue bitscore
        """


rule nextclade_sort:
    input:
        sequences="results/segment_{segment}.fasta",
        minimizer="minimizer.json",
    output:
        results="results/sort_{segment}.tsv",
    shell:
        """
        nextclade sort -m {input.minimizer} \
        -r {output.results}  {input.sequences} \
        --max-score-gap 0.3 --min-score 0.05 --min-hits 2  --all-matches
        """


rule find_sort_differences:
    input:
        sort_output="results/sort_{segment}.tsv",
        alignment_results="results/nextclade_{segment}.tsv",
        script="find_sort_differences.py",
    output:
        differences="results/sortdifferences_{segment}.tsv",
    shell:
        """
        python {input.script} \
            --sort {input.sort_output} \
            --alignment {input.alignment_results} \
            --output {output.differences}
        """


rule find_diamond_differences:
    input:
        diamond_output="results/diamond_{segment}.tsv",
        alignment_results="results/nextclade_{segment}.tsv",
        script="find_diamond_differences.py",
    output:
        differences="results/diamonddifferences_{segment}.tsv",
    shell:
        """
        python {input.script} \
            --diamond {input.diamond_output} \
            --alignment {input.alignment_results} \
            --output {output.differences}
        """
