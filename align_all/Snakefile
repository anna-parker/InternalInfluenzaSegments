datasets_in_gs_server = {
    "seg4": {
        "h3_h3n8", "h4_h4n6", "h5_h5n2", "h6_h6n2", "h7_h7n9", "h8_h8n4", "h9_h9n2", "h10_h10n7", "h11_h11n9", "h12_h12n5", "h13_h13n6", "h14_h14n5", "h15_h15n9", "h16_h16n3", "h17_h17n10", "h18_h18n11"
